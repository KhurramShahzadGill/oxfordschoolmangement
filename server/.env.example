# Copy this file to ".env" and fill in real values.

# Server
PORT=4000
CORS_ORIGIN=http://localhost:5173

# PostgreSQL connection string
# Local example:  postgresql://postgres:postgres@localhost:5432/school_db
# Supabase/cloud: copy the connection string from your provider
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/school_db

# Auth
JWT_SECRET=please-change-this-to-a-long-random-string
JWT_EXPIRES_IN=12h

# Password set for the seeded admin user (admin@oxford.edu) during migration
DEFAULT_ADMIN_PASSWORD=admin123
